{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"homeassistant": {
			"enabled": false,
			"type": "local",
			"command": [
				"uvx",
				"ha-mcp@latest"
			],
			"environment": {
				"HOMEASSISTANT_URL": "{file:~/.config/opencode/.ha_url}",
				"HOMEASSISTANT_TOKEN": "{file:~/.config/opencode/.ha_token}"
			}
		}
	},
	"lsp": {
		"gdscript-lsp": {
			"command": [
				"nc",
				"127.0.0.1",
				"6005"
			],
			"extensions": [
				".gd"
			]
		}
	}
}
